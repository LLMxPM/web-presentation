# 文件功能：提供生产 compose 模板所需环境变量示例，实际部署时应复制后替换密钥、域名和镜像标签。

DOCKERHUB_NAMESPACE=your-dockerhub-namespace
PLATFORM_VERSION=v0.0.0
WEB_PRESENTATION_IMAGE=your-dockerhub-namespace/web-presentation:v0.0.0
WEB_RUNTIME_IMAGE=your-dockerhub-namespace/web-runtime-vue:sha-c5273cf1564d

PUBLIC_BASE_URL=https://presentation.example.com
BACKEND_PUBLIC_BASE_URL=https://presentation.example.com
RUNTIME_PUBLIC_BASE_URL=https://presentation.example.com/runtime
GATEWAY_HTTP_PORT=80

POSTGRES_DB=web_presentation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-postgres-password
DATABASE_URL=postgresql+asyncpg://postgres:change-postgres-password@postgres:5432/web_presentation

REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=web_presentation

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-admin-password
DEFAULT_ADMIN_DISPLAY_NAME=平台系统管理员

APP_TIMEZONE=Asia/Shanghai
SESSION_SECURE=true
CORS_ORIGINS=["https://presentation.example.com"]

AI_ENABLED=true
AI_SECRET_ENCRYPTION_KEY=vmgRweOsDpMtYVW7SSpceINYcXlUHFNndAby6vRv0iA=

RUNTIME_BASE_URL=http://runtime:7373
RUNTIME_PREVIEW_JWKS_URL=http://backend:8000/.well-known/jwks.json
RUNTIME_PREVIEW_TOKEN_AUDIENCE=runtime-preview
RUNTIME_BUILD_TOKEN_AUDIENCE=runtime-build
RUNTIME_DIAGNOSTICS_TOKEN_AUDIENCE=runtime-diagnostics
RUNTIME_BACKEND_API_BASE_URL=http://backend:8000
RUNTIME_STANDALONE_PREVIEW_ENABLED=false

ASSET_STORAGE_DRIVER=local
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_BUCKET=
S3_REGION=
S3_PUBLIC_BASE_URL=

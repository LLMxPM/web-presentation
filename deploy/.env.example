# 文件功能：提供 production 编排所需环境变量示例，实际部署时复制为 deploy/.env 后替换密钥、域名和外部依赖地址。

# 本文件只供 deploy/docker-compose.production.yml 通过 env_file: .env 读取。
# 两个简化版 docker-compose.yml 与 docker-compose.with-deps.yml 不读取本文件。

# 对外访问地址。常规同域 Gateway 模式下：
# - BACKEND_PUBLIC_BASE_URL 等于平台入口。
# - RUNTIME_PUBLIC_BASE_URL 为平台入口追加 /runtime。
# - RUNTIME_SERVER_BASE_PATH 与 RUNTIME_PUBLIC_BASE_URL 的 URL path 一致，使用 /runtime/。
# 独立 Runtime 域名模式下：
# - RUNTIME_PUBLIC_BASE_URL 示例：https://runtime.example.com
# - RUNTIME_SERVER_BASE_PATH 使用 /，表示 Runtime 挂载在独立域名根路径。
# 如单独暴露 Backend 或 Runtime 域名，应改成对应公网地址，并同步调整 CORS_ORIGINS。
BACKEND_PUBLIC_BASE_URL=https://presentation.example.com
RUNTIME_PUBLIC_BASE_URL=https://presentation.example.com/runtime
CORS_ORIGINS=["https://presentation.example.com"]
SESSION_SECURE=true
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
LOG_FORMAT=json
ACCESS_LOG_ENABLED=false
CLIENT_ERROR_LOG_ENABLED=true
CLIENT_ERROR_LOG_MAX_BYTES=16384
PLAYWRIGHT_BROWSER_POOL_SIZE=2
PLAYWRIGHT_TASK_QUEUE_SIZE=16
PLAYWRIGHT_TASK_QUEUE_WAIT_TIMEOUT_SECONDS=60
PLAYWRIGHT_BROWSER_REUSE_ENABLED=true
PLAYWRIGHT_BROWSER_RECYCLE_TASK_COUNT=50
PLAYWRIGHT_BROWSER_RECYCLE_AGE_SECONDS=1800
DURABLE_JOB_LEASE_SECONDS=300
DURABLE_JOB_HEARTBEAT_SECONDS=30
RUNTIME_ARTIFACT_SWEEP_INTERVAL_SECONDS=30

# production 编排使用已有 PostgreSQL 与 Redis，目标数据库和用户需要提前创建。
DATABASE_URL=postgresql+asyncpg://wp_user:change-postgres-password@postgres.example.internal:5432/web_presentation
REDIS_URL=redis://:change-redis-password@redis.example.internal:6379/0
REDIS_KEY_PREFIX=web_presentation

# 首次启动时使用的默认平台管理员。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-admin-password
DEFAULT_ADMIN_DISPLAY_NAME=平台系统管理员

# AI 配置密钥用于加密用户模型凭证，正式部署前必须重新生成并长期保存。
# 它不是 API Key，也不是普通密码。必须是 Fernet 密钥：32 字节随机值的 URL-safe base64 编码，
# 通常长度为 44 个字符并以 = 结尾。更换该值会导致已有用户模型凭证密文无法解密。
# 生成示例：python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AI_ENABLED=true
AI_SECRET_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AI_AGENT_STREAM_IDLE_TIMEOUT_SECONDS=180
AI_AGENT_TOOL_STREAM_IDLE_TIMEOUT_SECONDS=600
AI_PAGE_MUTATION_CONCURRENCY=2
AI_PAGE_MUTATION_MAX_ACTIVE_JOBS=64
AI_PAGE_MUTATION_MAX_BATCH_SIZE=16
AI_PAGE_MUTATION_POLL_INTERVAL_SECONDS=0.5

# Backend 与 Runtime 的容器内网访问关系，通常无需修改。
# RUNTIME_BASE_URL 是 Backend 调 Runtime 的内网地址，不是浏览器访问地址。
RUNTIME_BASE_URL=http://runtime:7373
RUNTIME_PREVIEW_JWKS_URL=http://backend:8000/.well-known/jwks.json
RUNTIME_SERVICE_TOKEN_AUDIENCE=runtime-backend
RUNTIME_PREVIEW_TOKEN_AUDIENCE=runtime-preview
RUNTIME_BUILD_TOKEN_AUDIENCE=runtime-build
RUNTIME_DIAGNOSTICS_TOKEN_AUDIENCE=runtime-diagnostics
RUNTIME_BACKEND_API_BASE_URL=http://backend:8000
RUNTIME_SERVER_HOST=0.0.0.0
RUNTIME_SERVER_PORT=7373
# Runtime Vite 资源挂载路径，应等于 RUNTIME_PUBLIC_BASE_URL 的 URL path。
# 例如 https://presentation.example.com/runtime 对应 /runtime/，https://runtime.example.com 对应 /。
RUNTIME_SERVER_BASE_PATH=/runtime/
RUNTIME_LOG_LEVEL=info
RUNTIME_LOG_FORMAT=json
RUNTIME_ACCESS_LOG_ENABLED=false
RUNTIME_STANDALONE_PREVIEW_ENABLED=false
RUNTIME_DIAGNOSTICS_REQUEST_TIMEOUT_SECONDS=180
RUNTIME_BUILD_REQUEST_TIMEOUT_SECONDS=900
RUNTIME_VITE_TASK_CONCURRENCY=2
RUNTIME_VITE_TASK_QUEUE_SIZE=16
RUNTIME_VITE_TASK_QUEUE_WAIT_TIMEOUT_MS=30000
RUNTIME_VITE_DIAGNOSTICS_WEIGHT=3
RUNTIME_BUILD_WORKER_MAX_OLD_SPACE_MB=2048
RUNTIME_BUILD_WORKER_TIMEOUT_MS=600000
RUNTIME_DIAGNOSTICS_WORKER_TIMEOUT_MS=120000
RUNTIME_DIAGNOSTICS_WORKER_REUSE_ENABLED=true
RUNTIME_DIAGNOSTICS_WORKER_MAX_TASKS=25
RUNTIME_DIAGNOSTICS_WORKER_MAX_AGE_MS=1800000
RUNTIME_DIAGNOSTICS_WORKER_RSS_RECYCLE_RATIO=0.75

# 资源存储。local 会写入 backend-data volume；对象存储部署时改为 s3 并补齐 S3_*。
ASSET_STORAGE_DRIVER=local
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_BUCKET=
S3_REGION=
S3_PUBLIC_BASE_URL=

# 文件功能：提供后台服务本地开发所需的示例环境变量。
APP_NAME=页面管理后台
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
LOG_FORMAT=json
ACCESS_LOG_ENABLED=true
CLIENT_ERROR_LOG_ENABLED=true
CLIENT_ERROR_LOG_MAX_BYTES=16384
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/web_presentation
DATABASE_CONNECT_TIMEOUT_SECONDS=10
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=web_presentation
REDIS_HEALTHCHECK_TIMEOUT_SECONDS=2
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123456
DEFAULT_ADMIN_DISPLAY_NAME=平台系统管理员
SESSION_COOKIE_NAME=wp_user_session
SESSION_TTL_HOURS=24
SESSION_SECURE=false
RUNTIME_BASE_URL=http://127.0.0.1:7373
RUNTIME_PUBLIC_BASE_URL=http://127.0.0.1:7373
RUNTIME_SHARED_SECRET=change-me
RUNTIME_SERVICE_TOKEN_AUDIENCE=runtime-backend
RUNTIME_REQUEST_TIMEOUT_SECONDS=10
RUNTIME_PREVIEW_ARTIFACT_TTL_SECONDS=3600
RUNTIME_BUILD_STATE_TTL_SECONDS=604800
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000
PLAYWRIGHT_TASK_CONCURRENCY=1
AI_ENABLED=true
AI_SECRET_ENCRYPTION_KEY=vmgRweOsDpMtYVW7SSpceINYcXlUHFNndAby6vRv0iA=
AI_AGENT_OS_ID=backend-agentos
AI_AGENT_TOKEN_TTL_SECONDS=600
AI_TOOL_AUTH_WINDOW_SECONDS=1800
AI_TOOL_AUTH_MAX_SECONDS=7200
AI_LLM_HTTP_TRACE_ENABLED=false
AI_LLM_HTTP_TRACE_DIR=.tmp/llm-http-trace
AI_LLM_HTTP_TRACE_BODY_MAX_BYTES=200000
AI_IMAGE_TRANSPORT_MODE=auto
AI_IMAGE_ATTACHMENT_MAX_BYTES=10485760
AI_IMAGE_MODEL_URL_REUSE_WINDOW_SECONDS=7200
AI_IMAGE_MODEL_URL_TTL_SECONDS=21600
AI_IMAGE_MODEL_URL_EXPIRY_SAFETY_SECONDS=300
AI_IMAGE_HISTORY_MAX_HYDRATED_IMAGES=10
AI_IMAGE_HISTORY_MAX_HYDRATED_BYTES=31457280
PAGE_SCREENSHOT_DEFAULT_VIEWPORT_WIDTH=1920
PAGE_SCREENSHOT_DEFAULT_VIEWPORT_HEIGHT=1080
PAGE_SCREENSHOT_MAX_VIEWPORT_WIDTH=4096
PAGE_SCREENSHOT_MAX_VIEWPORT_HEIGHT=4096
PAGE_SCREENSHOT_TIMEOUT_SECONDS=45
PAGE_SCREENSHOT_VISUAL_READY_TIMEOUT_SECONDS=25
PAGE_SCREENSHOT_BATCH_CONCURRENCY=2
PAGE_SCREENSHOT_QUEUE_CONCURRENCY=1
PAGE_SCREENSHOT_QUEUE_POLL_INTERVAL_SECONDS=1
PAGE_SCREENSHOT_JOB_LEASE_SECONDS=180
PAGE_SCREENSHOT_AI_WAIT_TIMEOUT_SECONDS=90
PAGE_SCREENSHOT_LOCAL_ROOT=data
PAGE_SCREENSHOT_BROWSER_EXECUTABLE_PATH=
OBJECT_CACHE_IDLE_DAYS=30
OBJECT_CACHE_MAX_BYTES=10737418240
OBJECT_CACHE_SWEEP_INTERVAL_SECONDS=21600

# 资源管理器与对象存储配置
ASSET_STORAGE_DRIVER=local
# S3_ENDPOINT_URL=https://s3.your-region.amazonaws.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# 字体可选走公开 bucket，其他资源继续走 S3_BUCKET 私有 bucket。

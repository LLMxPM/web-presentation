# 文件功能：提供后台服务本地开发所需的示例环境变量。
APP_NAME=页面管理后台
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
APP_TIMEZONE=Asia/Shanghai
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/web_presentation
DATABASE_CONNECT_TIMEOUT_SECONDS=10
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=web_presentation
REDIS_HEALTHCHECK_TIMEOUT_SECONDS=2
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123456
DEFAULT_ADMIN_DISPLAY_NAME=平台系统管理员
SESSION_COOKIE_NAME=wp_user_session
SESSION_TTL_HOURS=24
SESSION_SECURE=false
RUNTIME_BASE_URL=http://127.0.0.1:7373
RUNTIME_PUBLIC_BASE_URL=http://127.0.0.1:7373
RUNTIME_SHARED_SECRET=change-me
RUNTIME_SERVICE_TOKEN_AUDIENCE=runtime-backend
RUNTIME_REQUEST_TIMEOUT_SECONDS=10
RUNTIME_PREVIEW_ARTIFACT_TTL_SECONDS=3600
RUNTIME_BUILD_STATE_TTL_SECONDS=604800
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000
AI_ENABLED=true
AI_SECRET_ENCRYPTION_KEY=vmgRweOsDpMtYVW7SSpceINYcXlUHFNndAby6vRv0iA=
AI_AGENT_OS_ID=backend-agentos
AI_AGENT_TOKEN_TTL_SECONDS=600
AI_TOOL_AUTH_WINDOW_SECONDS=1800
AI_TOOL_AUTH_MAX_SECONDS=7200
AI_RUN_ACTIVE_TTL_SECONDS=86400
AI_RUN_PAUSED_TTL_SECONDS=604800
AI_RUN_TERMINAL_TTL_SECONDS=86400
AI_RUN_EVENT_MAXLEN=5000
AI_IMAGE_TRANSPORT_MODE=auto
AI_IMAGE_ATTACHMENT_MAX_BYTES=10485760
